{
  "functions": {
    "app/api/bigfive/download-pdf/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "app/api/fortune/download-pdf/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "crons": [
    {
      "path": "/api/cron/step-email",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/order-form-reminders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/booking-reminders",
      "schedule": "0 0 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.makers.tokyo"
        }
      ],
      "destination": "https://makers.tokyo/:path*",
      "permanent": true
    }
  ]
}

